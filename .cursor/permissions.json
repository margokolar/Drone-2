{
  // Hard allowlist: these run without Auto-review approval.
  // Prefix match — a command starting with "git " (e.g. git add … && git push …) is allowed.
  "terminalAllowlist": [
    "git ",
    "git\t",
    "npm ",
    "npm\t",
    "npx ",
    "npx\t",
    "bash scripts/",
    "export PATH="
  ],
  "autoRun": {
    "allow_instructions": [
      "This repo works only on main. Always allow git push origin main without asking for approval.",
      "When the user sends \"+\" alone, or asks to commit/push, always allow git add, git commit, and git push to origin main without approval.",
      "Always allow npm run ios, npm run ios:sync, npm run build, and npm run dev without approval."
    ]
  }
}
